// Online Class — data model
// Local dev uses SQLite. For Vercel production, switch provider to "postgresql"
// and set DATABASE_URL to your Postgres connection string (see DEPLOY.md).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model User {
  id          String       @id @default(cuid())
  name        String
  email       String       @unique
  password    String
  role        String       @default("STUDENT") // "LECTURER" | "STUDENT"
  matric      String?
  createdAt   DateTime     @default(now())

  courses       Course[]        @relation("LecturerCourses")
  enrollments   Enrollment[]
  attendances   Attendance[]
  sessionAccess SessionAccess[]
  quizResponses QuizResponse[]
}

model Course {
  id          String         @id @default(cuid())
  code        String
  title       String
  description String?
  lecturerId  String
  lecturer    User           @relation("LecturerCourses", fields: [lecturerId], references: [id], onDelete: Cascade)
  createdAt   DateTime       @default(now())

  enrollments Enrollment[]
  materials   Material[]
  sessions    ClassSession[]
  quizzes     Quiz[]
}

model Enrollment {
  id        String   @id @default(cuid())
  courseId  String
  studentId String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  student   User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([courseId, studentId])
}

model Material {
  id        String   @id @default(cuid())
  courseId  String
  title     String
  fileName  String
  fileUrl   String
  size      Int      @default(0)
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model ClassSession {
  id        String       @id @default(cuid())
  courseId  String
  title     String
  startsAt  DateTime
  endsAt    DateTime
  startedAt DateTime?    // set when the lecturer goes live
  mode      String       @default("PHYSICAL") // "PHYSICAL" | "ONLINE"
  location  String?      // room name or meeting link
  shareId   String       @unique @default(cuid()) // students access only via this link
  course    Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  createdAt DateTime     @default(now())

  attendances Attendance[]
  access      SessionAccess[]
}

// A student "unlocks" a session by opening its share link.
model SessionAccess {
  id        String       @id @default(cuid())
  sessionId String
  studentId String
  session   ClassSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student   User         @relation(fields: [studentId], references: [id], onDelete: Cascade)
  createdAt DateTime     @default(now())

  @@unique([sessionId, studentId])
}

model Attendance {
  id        String       @id @default(cuid())
  sessionId String
  studentId String
  markedAt  DateTime     @default(now())
  status    String       @default("PRESENT") // "PRESENT" | "LATE"
  session   ClassSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student   User         @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([sessionId, studentId])
}

model Quiz {
  id         String         @id @default(cuid())
  courseId   String
  lecturerId String
  title      String
  kind       String         @default("POLL") // "POLL" | "QUIZ"
  createdAt  DateTime       @default(now())
  course     Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  questions  QuizQuestion[]
}

model QuizQuestion {
  id        String         @id @default(cuid())
  quizId    String
  text      String
  order     Int            @default(0)
  quiz      Quiz           @relation(fields: [quizId], references: [id], onDelete: Cascade)
  options   QuizOption[]
  responses QuizResponse[]
}

model QuizOption {
  id         String         @id @default(cuid())
  questionId String
  text       String
  isCorrect  Boolean        @default(false)
  order      Int            @default(0)
  question   QuizQuestion   @relation(fields: [questionId], references: [id], onDelete: Cascade)
  responses  QuizResponse[]
}

model QuizResponse {
  id         String       @id @default(cuid())
  questionId String
  optionId   String
  studentId  String
  createdAt  DateTime     @default(now())
  question   QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  option     QuizOption   @relation(fields: [optionId], references: [id], onDelete: Cascade)
  student    User         @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([questionId, studentId])
}
